#! /usr/bin/env bash

# Source common env
# =================================================================

ENV_PATH=${HOME}/.env
source ${ENV_PATH}/bashrc.common

# Own environment
# =================================================================

MYMAIL=''
PS1="\t ${SF_GREEN}${SF_BOLD}\u@\h ${SF_BLUE}\w ${SF_GREEN}\$\[\e[m\] \[\033[0m\] ${SF_NORM}"

# GoTo
# -----------------------------------------------------------------

# Tools
# -----------------------------------------------------------------

# Networking
# -----------------------------------------------------------------

add-alias ip-links      'ip link list'
add-alias ip-routes     'ip route list'
add-alias ipt-rules     'sudo iptables --list-rules'


echo "Source file ./.env/bashrc.user          [${GREEN}OK${NORM}]"
