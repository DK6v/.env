
[init]
	defaultBranch = main
[diff]
    tool = kdiff3
[difftool]
    prompt = false
    keepBackup = false
    trustExitCode = false
[mergetool]
    prompt = false
    keepBackup = false
    keepTemporaries = false
[merge]
    tool = kdiff3
[color]
	ui = auto
[core]
	editor = code --wait
[include]
  path = ~/.env/gitconfig.aliases